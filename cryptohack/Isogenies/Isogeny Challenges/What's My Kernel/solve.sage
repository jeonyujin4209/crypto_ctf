"""What's My Kernel (70pts) — recover SIDH kernel coefficient.

The bug: P_b, Q_b = P_a, Q_a (same basis). So phi(P_a), phi(Q_a) are
revealed publicly. Since kernel R = P_a + n*Q_a satisfies phi(R) = 0,
we have phi(P_a) = -n * phi(Q_a) in E_A's 2^216 torsion. Solve for n
via Pohlig-Hellman discrete log in cyclic group of order 2^216.
"""
def long_to_bytes(n):
    s = hex(int(n))[2:]
    if len(s) % 2:
        s = "0" + s
    return bytes.fromhex(s)

l_a, l_b = 2, 3
e_a = 216
e_b = 137
p = (l_a^e_a) * (l_b^e_b) - 1
F.<i> = GF(p^2, modulus=[1, 0, 1])
E = EllipticCurve(F, [0, 1])

P_a = E(20136586736114246501835971171967338480311516382940373533952481525296357878861783566151781007236212556832934545674854612011626195700*i + 17814453364935074861383131667083124325683937346696984368949852778058904726511787029450818202901070694186758274352723265991464877103,
        1271771361808985304712159481749593042413672298743174888306246138805367680531766658529560708954342114713164882433446311394561215114*i + 2458042406822607338623223129871544282558479021229618369701845857877994575575856044528094950443550864121494484286802649880921739708)

Q_a = E(21803015129321483945529412215838779132813252821045317544411028404348688068008744729098809691017674062502155948983091074705848044135*i + 13082212877505354759913698066147486474050693412889330975858763468321298287624363965619656101414455426060476491447329452631424163500,
        19506407896382533931237830326416853938397569146136935331864946437347935359679645132170606348699875016125904420682336351889485252410*i + 15043791945562477356073952628550508300788370803355011888730813281302739269433285656956641625470216196554392274696427278619285685068)

# Codomain
EA = EllipticCurve(F, [
    7712764739056777529792987423646889337402217452473623818903331120045456102569165026218420598248767317603435401713968530490357307795*i + 9758256230562931813080263636289065758287866439147365597646450723337045772222738857092908727407334585972591094553818411432094464777,
    14111394476215446245563948462935499285975180615187777011147664203502283568940589822501200201326292294803458962166963919769448620180*i + 13109242201116529741594122295056720779908966260700480865503735602954357430118695171517916549873840990587047235292662060447639572670
])

phi_P = EA(23952894958295317549971106723685134737893696601669145219207726439639811367925016451999242069428068943047723238819908252774486766337*i + 4305462457135268462142264590143148158970142912257623729725051176173395849821915511030491264545144391647666649473524326829794956856,
           22266818407313663485605006496877581796532115423284800341915760912566163458303144152456856269304745399393537962410019487747495397607*i + 4419726782686001239678340241398527123282988628405899347621803247232804830981975088769950625242092440018396292009058977329258215839)

phi_Q = EA(831800239128719623934089118985220873854807542447712150093021613769936785750351133960474011564870745205073463311921316788621778431*i + 15402744117044645512001884312795650889329806711970659247428390301404175742876408129656571894858120059888562036870272272006051303602,
           15910085843685894625838711841842809245031051484845379580040299498782585224630037907430690257895403864870016080008595192352518845469*i + 11737105265834767072297460524082128066585409511311853470189225057161817943162394756398035248684338249353988301973489992957376234646)

# phi(P_a) = -n * phi(Q_a). Solve for n.
# DL in cyclic subgroup of order 2^216 of E_A
order = l_a^e_a
print(f"phi_Q order: {phi_Q.order()}")
print(f"phi_P order: {phi_P.order()}")

neg_phi_P = -phi_P
n = discrete_log(neg_phi_P, phi_Q, ord=order, operation='+')
print(f"n = {n}")
print(f"bytes: {long_to_bytes(int(n))}")

"""Dual Masters — use Sage's built-in `isogeny.dual()` method.

Key lesson: Sage's `EllipticCurveIsogeny` has a `.dual()` method that
returns the TRUE dual isogeny (no automorphism ambiguity). Don't roll
your own via `codomain().isogeny(K) * iso` — that custom path picks an
arbitrary iso which may land in the wrong Aut(E_0) class.
"""
proof.all(False)

l_a, l_b = 2, 3
e_a = 216
e_b = 137
p = (l_a^e_a) * (l_b^e_b) - 1
F.<i> = GF(p^2, modulus=[1, 0, 1])
E = EllipticCurve(F, [0, 1])

P_a = E(20136586736114246501835971171967338480311516382940373533952481525296357878861783566151781007236212556832934545674854612011626195700*i + 17814453364935074861383131667083124325683937346696984368949852778058904726511787029450818202901070694186758274352723265991464877103,
        1271771361808985304712159481749593042413672298743174888306246138805367680531766658529560708954342114713164882433446311394561215114*i + 2458042406822607338623223129871544282558479021229618369701845857877994575575856044528094950443550864121494484286802649880921739708)
Q_a = E(21803015129321483945529412215838779132813252821045317544411028404348688068008744729098809691017674062502155948983091074705848044135*i + 13082212877505354759913698066147486474050693412889330975858763468321298287624363965619656101414455426060476491447329452631424163500,
        19506407896382533931237830326416853938397569146136935331864946437347935359679645132170606348699875016125904420682336351889485252410*i + 15043791945562477356073952628550508300788370803355011888730813281302739269433285656956641625470216196554392274696427278619285685068)

EA = EllipticCurve(F, [
    15647464439428927741867845580767694684222523016251895093602328385380654388145388778115672931157828708127948851349755210959710992823*i + 18519701628642104957465933782270611113379500730906473687377196168245135786408360125497897711207297387671119962606217672095858390120,
    7633645641925656224162547557120979142458288939027826632263622435013191750759424333538814072346087746161472785937079595640620414463*i + 19378290131372561524504737884022331022393059506539098406878225963551347653933679233858710469551163367570754633517180433892819440342
])

phi_a_Q_b = EA(15299431986544116565289603141128936730054296135592165196922848777121350286377485832136840240125657196209757793781083819580249068968*i + 17051219994281676546361123230640448840845340329176128231730176689245736814461968605143814113803812890865243421542880279156556244461,
               3998868285015588876268560462444888175225579707550791385515097131316476642530563104222732513021020953406505731356727753586817062110*i + 19576513237814293888726624230603574617889471255277258991796653332639293951210409486398735758705505503362959553658315915727351406457)


def long_to_bytes(k):
    s = hex(int(k))[2:]
    if len(s) % 2:
        s = "0" + s
    return bytes.fromhex(s)


# Step 1: phi_hat : E_A → (iso of E) — compose with iso back to E
# Step 2: .dual() flips it to E → E_A, which IS phi (up to sign)
phi_hat = EA.isogeny(phi_a_Q_b, algorithm="factored")
phi_hat = phi_hat.codomain().isomorphism_to(E) * phi_hat
phi_recovered = phi_hat.dual()  # ← Sage built-in, handles aut correctly

# Step 3: phi(P_a)
phi_a_P_b = phi_recovered(P_a)

# Step 4: DL with sign disambiguation
for t_a in [-1, 1]:
    for t_b in [-1, 1]:
        try:
            n = int(discrete_log(t_a * phi_a_P_b, t_b * phi_a_Q_b, ord=2^216, operation='+'))
        except Exception:
            continue
        raw = long_to_bytes(n)
        if len(raw) >= 5 and all(32 <= c < 127 for c in raw):
            print(f"[+] (t_a={t_a}, t_b={t_b}): n = {n}")
            print(f"[+] FLAG: crypto{{{raw.decode()}}}")

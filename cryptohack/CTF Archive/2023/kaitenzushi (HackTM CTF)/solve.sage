"""
kaitenzushi (HackTM CTF 2023)

Vulnerability:
  N = p*q with two distinct representations  x_i^2 + e*y_i^2 = N (i=1,2).
  The "hint" rotates (x1,x2) and (y1,y2) by the same angle theta in R^2.
  Rotation preserves M*M^T entries (Sx=x1^2+x2^2, Sy=y1^2+y2^2,
  Pxy=x1y1+x2y2) and det(M)=x1*y2-x2*y1.  Sum of the two norm equations:
       Sx + e*Sy = 2N    =>  e is recoverable from the high precision
                              floats (e is small ~256 bit, dividing wipes
                              out the rounding).
  Then Sx, Sy come out as exact integers, leaving Pxy as the only noisy
  invariant.  Eliminating x2, y2 via (Sx, Sy) and using Pxy yields a
  quadratic in v=y1^2 with coefficients that depend (linearly/quadratically)
  on the noisy Pxy.  Numerically solving + rounding to integer gives v
  exactly because the quadratic has only ~1280-bit precision worth of
  information stretching across the float (the field has 1337 bits).

  Once (x1,y1,x2,y2) are known, gcd(N, x1*y2 - x2*y1) (or +) splits N.
  Standard RSA decrypt with extra XOR mask (x1 ^ y1 ^ x2 ^ y2) over the
  flag.
"""

def long_to_bytes(n):
    n = int(n)
    return n.to_bytes((n.bit_length()+7)//8, 'big')

n = 
c = 

F = RealField(1337)

x1f = F("9.")
x2f = F("-1.")
y1f = F("9.")
y2f = F("2.")

# --- step 1: recover e ---
Sx_f = x1f**2 + x2f**2
Sy_f = y1f**2 + y2f**2
Pxy_f = x1f*y1f + x2f*y2f

# Sy small enough relative to precision: round directly.
Sy = ZZ(round(Sy_f))
# e = (2N - Sx) / Sy. Division by Sy ~2^1278 cancels the 2^198 noise in Sx.
e = ZZ(round((2*n - Sx_f) / Sy_f))
assert is_prime(e) and e.bit_length() == 256
Sx = 2*n - e*Sy   # exact

# --- step 2: solve quadratic in v = y1^2 using noisy Pxy ---
# Derivation: from x_1^2 + e y_1^2 = N (and x2,y2 analogous), Sx, Sy known,
# Pxy known approximately:
#   x_1 y_1 = (Pxy^2 - Sx*Sy + N*Sy + (Sx - e*Sy) v) / (2 Pxy)
#   (x_1 y_1)^2 = (N - e v) v
# Combine -> quadratic in v.
A_f = Pxy_f**2 - Sx*Sy + n*Sy
B = Sx - e*Sy
c2_f = B**2 + 4*Pxy_f**2*e
c1_f = 2*A_f*B - 4*Pxy_f**2*n
c0_f = A_f**2

disc = c1_f**2 - 4*c2_f*c0_f
sd = sqrt(disc)
candidates = [(-c1_f + sd) / (2*c2_f), (-c1_f - sd) / (2*c2_f)]

x1 = y1 = x2 = y2 = None
for v_f in candidates:
    v = ZZ(round(v_f))
    u = n - e*v
    if u <= 0 or v <= 0:
        continue
    if u.is_square() and v.is_square():
        x1 = isqrt(u); y1 = isqrt(v)
        assert x1**2 + e*y1**2 == n
        x2_sq = Sx - x1**2
        y2_sq = Sy - y1**2
        if x2_sq.is_square() and y2_sq.is_square():
            x2 = isqrt(x2_sq); y2 = isqrt(y2_sq)
            assert x2**2 + e*y2**2 == n
            break

assert x1 is not None, "failed to recover (x1,y1,x2,y2)"
print(f"[+] recovered x1,y1,x2,y2 (bit lengths "
      f"{x1.nbits()}, {y1.nbits()}, {x2.nbits()}, {y2.nbits()})")

# --- step 3: factor n via cross product ---
p = None
for D in (x1*y2 - x2*y1, x1*y2 + x2*y1):
    g = gcd(D, n)
    if 1 < g < n:
        p = g; break
assert p is not None
q = n // p
assert p*q == n and is_prime(p) and is_prime(q)
print(f"[+] p = {p}")
print(f"[+] q = {q}")

# --- step 4: RSA decrypt + XOR ---
phi = (p-1)*(q-1)
d = inverse_mod(e, phi)
m_xored = power_mod(c, d, n)
mask = x1 ^^ y1 ^^ x2 ^^ y2   # `^^` is XOR in .sage (preparser)
flag_int = m_xored ^^ mask
flag = long_to_bytes(int(flag_int))
print("[+] flag =", flag)

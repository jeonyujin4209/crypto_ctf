"""
d-phi-enc (HackTM CTF 2023)

Vulnerability:
  e=3, ed = 1 mod phi  =>  3d = 1 + k*phi  with k in {1,2} (since 0 < 3d/phi < 3).
  Cubing: 27 enc_d ≡ (1 + k*phi)^3 (mod n).
  Let u = n - phi = p+q-1.  Then 1 + k*phi ≡ 1 - k*u (mod n).
  So  P1(u) = (1 - k*u)^3 - 27*enc_d ≡ 0 (mod n).   [degree 3 in u]
  Also enc_phi = phi^3 ≡ -u^3 (mod n), so  P2(u) = u^3 + enc_phi ≡ 0 (mod n).  [degree 3]

Both polynomials in u vanish modulo n; polynomial GCD mod n collapses to a linear factor
(u - root). That gives p+q = u+1, factor n, recover d, decrypt enc_flag.

Coppersmith small_roots fails here because u ~ 2*sqrt(n) which exceeds n^(1/d) bound for
both d=2 and d=3.  Two-equation gcd kills the problem instantly.
"""

n = 
enc_d = 
enc_phi = 
enc_flag = 

e = 3
ZN = Zmod(n)
P.<u> = PolynomialRing(ZN)


def poly_gcd_mod_n(a, b):
    """Half-extended Euclidean polynomial GCD over Zmod(n).
    May internally fail if a leading coeff is non-invertible mod n;
    that itself would leak a factor of n (we don't use it here)."""
    while b != 0:
        a, b = b, a % b
    return a


for k in [1, 2]:
    P1 = (1 - k * u) ** 3 - 27 * enc_d
    P2 = u ** 3 + enc_phi
    g = poly_gcd_mod_n(P1, P2)
    if g.degree() < 1:
        continue
    g = g.monic()
    if g.degree() == 1:
        u_val = ZZ(-g[0])
        s = u_val + 1                      # p+q
        disc = s * s - 4 * n
        sq = isqrt(disc)
        if sq * sq != disc:
            continue
        p = (s + sq) // 2
        q = (s - sq) // 2
        if p * q != n:
            continue
        phi = (p - 1) * (q - 1)
        d = inverse_mod(e, phi)
        m = power_mod(enc_flag, d, n)
        mi = int(m)
        flag = mi.to_bytes((mi.bit_length() + 7) // 8, 'big')
        print(f"k={k}")
        print(f"p={p}")
        print(f"q={q}")
        print("FLAG:", flag.decode(errors='replace'))
        raise SystemExit(0)

print("FAILED")
raise SystemExit(1)
